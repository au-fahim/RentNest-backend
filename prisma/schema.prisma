// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  TENANT
  LANDLORD
  ADMIN
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  ACTIVE
  COMPLETED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

model User {
  id       String  @id @default(uuid())
  name     String
  email    String  @unique
  password String
  role     Role
  isBanned Boolean @default(false)

  properties     Property[]
  rentalRequests RentalRequest[] @relation("TenantRequests")
  reviews        Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Category {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?

  properties Property[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

model Property {
  id          String   @id @default(uuid())
  title       String
  description String
  price       Float
  location    String
  amenities   String[]
  isAvailable Boolean  @default(true)

  landlordId String
  landlord   User   @relation(fields: [landlordId], references: [id])

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  rentalRequests RentalRequest[]
  reviews        Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("properties")
}

model RentalRequest {
  id          String        @id @default(uuid())
  status      RequestStatus @default(PENDING)
  moveInDate  DateTime
  moveOutDate DateTime

  tenantId String
  tenant   User   @relation("TenantRequests", fields: [tenantId], references: [id])

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])

  payment Payment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("rental_requests")
}

model Payment {
  id            String        @id @default(uuid())
  amount        Float
  transactionId String        @unique
  method        String
  provider      String
  status        PaymentStatus @default(PENDING)
  paidAt        DateTime?

  rentalRequestId String        @unique
  rentalRequest   RentalRequest @relation(fields: [rentalRequestId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payments")
}

model Review {
  id      String @id @default(uuid())
  rating  Int
  comment String

  tenantId String
  tenant   User   @relation(fields: [tenantId], references: [id])

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reviews")
}
